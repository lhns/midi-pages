# midi-pages example configuration.
# Copy to config.toml and edit. Run `midi-pages --list-ports` to see the
# exact port names reported by your OS.
#
# Two transport modes (per device):
#
#   mode = "per_port"   (default, recommended)
#       The proxy creates ONE virtual MIDI endpoint PER PAGE, named
#       `<device-slug>-page<N>`. Each page presents an identical
#       Launchpad/APC layout to the host. No 7-bit MIDI ceiling; up to
#       16+ pages possible. On Linux/macOS endpoints are created
#       natively via `midir`. On Windows the proxy calls Windows MIDI
#       Services (see ADR 0012); the WMS runtime DLL must be installed.
#
#   mode = "note_offset"
#       Single host port pair; pages encoded by adding `note_offset` to
#       the note number. Fits at most ~2 pages of 64 pads
#       (pages * note_offset must be <= 128). Requires host_port_in /
#       host_port_out to be set.
#
# Three page-navigation usage modes (combined freely; see ADR 0007):
#
#   Mode A — sequential
#       Configure `next_page_button` and/or `previous_page_button`.
#       Walk pages with two physical buttons. The button is lit with the
#       active color for as long as it is held, then returns to the
#       inactive color on release.
#
#   Mode B — direct jump
#       Configure `page_buttons` — one button per page. Tapping a button
#       jumps persistently to that page. The button LEDs always indicate
#       the active page. Combine freely with Mode A buttons.
#
#   Mode C — hold-to-preview
#       Configure `page_buttons` AND `page_buttons_hold_to_preview = true`.
#       Hold a page button to TEMPORARILY swap the grid to that page —
#       interactive: pressing other pads with another finger fires on
#       the previewed page. Releasing reverts to the persistent page.
#       The persistent page is moved only via next/previous_page_button.
#
# Multiple `[[device]]` blocks are supported and run side by side in a
# single process. Each device gets its own page-navigation state, virtual
# host ports, reconnect supervisor, and presence watchdog. The proxy can
# also start with one or more physical devices missing — the supervisor
# keeps retrying and picks them up the moment they're plugged in.
# Registration runs in strict config-declaration order across devices, so
# WinMM device-index assignments stay stable across runs (important for
# host apps like DasLight that persist MIDI bindings by index).

[[device]]
name             = "Launchpad Mini MK3"
# `port_match` is a substring matched against the OS-reported MIDI port
# names. By default the same substring is used for both input and output.
# For devices whose input and output ports have completely different
# names, you can write a split form instead:
#
#   port_match = { in = "Weird IN", out = "Weird OUT" }
#
# On Windows the Mini MK3 enumerates as TWO ports: `LPMiniMK3 MIDI`
# (port 1, the DAW port) and `MIDIIN2 (LPMiniMK3 MIDI)` / `MIDIOUT2
# (LPMiniMK3 MIDI)` (port 2, the MIDI port). Programmer-mode SysEx and
# pad I/O go through port 2. The substring `(LPMiniMK3 MIDI)` (with both
# parens) selects port 2 because port 1's name has no parens at all.
# On Linux/macOS the simpler `"Launchpad Mini MK3"` substring works.
port_match       = "(LPMiniMK3 MIDI)"
driver           = "mini_mk3"
mode             = "per_port"
pages            = 4
# Switch the device to programmer mode on startup so SysEx LED control works.
boot_sysex       = "F0 00 20 29 02 0D 0E 01 F7"

# Mode A: top-row arrows on the Mini MK3 are CC 91/92.
next_page_button     = { kind = "cc", number = 91 }
previous_page_button = { kind = "cc", number = 92 }

# Mode B (optional): side-strip buttons act as both page indicators and
# direct-jump targets. Each entry's optional `page = N` field pins it to
# a specific page; entries without `page` auto-assign in declaration
# order to the lowest free page index. Each entry can also override
# `hold_to_preview` for itself only, letting you mix tap and hold
# buttons on the same device. May be shorter than `pages` (those high
# pages are reachable only via next/previous_page_button); cannot be
# longer.
#
# Pages are zero-indexed: with `pages = 4`, valid `page = N` values are
# 0, 1, 2, 3.
#
# Auto-assignment walks declaration order: each unconstrained entry
# claims the lowest free page index at that moment. An explicit
# `page = N` later in the list is taken as written and may collide with
# an earlier auto-assigned entry; both buttons then map to the same
# page (allowed, intentional).
page_buttons = [
  { kind = "cc", number = 89 },
  { kind = "cc", number = 79 },
  { kind = "cc", number = 69 },
  { kind = "cc", number = 59 },
]

# Same, with per-entry overrides:
# page_buttons = [
#   { kind = "cc", number = 89, hold_to_preview = true },   # this button only previews
#   { kind = "cc", number = 79 },                           # uses device default
#   { kind = "cc", number = 69, page = 5 },                 # remap to page 5
# ]

# Mode C (default false): when true, page_buttons act as hold-to-preview
# instead of direct jump. Persistent page is then moved only via
# next/previous_page_button. Per-button `hold_to_preview` overrides this.
# page_buttons_hold_to_preview = true

# Optional per-device LED colors. Every field is optional. The in-code
# fallbacks are deliberately minimal and device-agnostic: active=1 (lit on
# essentially every controller) and inactive=0 (off). Set the block below
# for the recommended Mini MK3 palette out of the box.
#
# Cascade:
#   active           = tap page button on its persistent (active) page.
#   inactive         = tap page button on any other page.
#   preview          = page button while held in Mode C (defaults to active).
#   active_cycle     = next/previous_page_button while held (defaults to active).
#   inactive_cycle   = next/previous_page_button when idle (defaults to inactive).
#   active_preview   = hold-to-preview page button on the persistent page,
#                      when NOT held (defaults to active).
#   inactive_preview = hold-to-preview page button on any other page,
#                      when NOT held (defaults to inactive).
#
# Recommended Mini MK3 palette (21=green, 1=dim white, 13=yellow, 45=blue —
# blue marks hold-mode page buttons so they're visually distinct from tap):
colors = { active = 21, inactive = 1, preview = 13, active_preview = 45 }

# Buttons pinned to page 0 in both directions: presses always fire on page 0
# and host LED writes for them on page 0 always reach the device, regardless
# of which page is currently visible or being previewed. Useful for a
# transport row, master mute, etc. See ADR 0014.
#
# global_buttons = [
#   { kind = "note", number = 11 },
#   { kind = "note", number = 12 },
# ]

# In per_port mode the proxy auto-generates port names from `name`.
# Override with an explicit prefix if you want shorter names:
# page_port_prefix = "lp"

[[device]]
name             = "APC mini"
port_match       = "APC MINI"
driver           = "apc_mini"
mode             = "per_port"
pages            = 8
# APC mini has no top-row arrow CCs; pick two grid corners or any unused
# notes. Both fields are optional, Mode A only needs at least one of them.
next_page_button     = { kind = "note", number = 98 }
previous_page_button = { kind = "note", number = 99 }

# Recommended APC mini palette (override the universal active=1 / inactive=0
# defaults with the documented APC velocity-as-color codes):
# colors = { active = 1, inactive = 0, preview = 5, active_preview = 5 }

# Example of note_offset mode (capped at 2 pages with default offset of 64):
#
# [[device]]
# name             = "APC mini (legacy)"
# port_match       = "APC MINI"
# driver           = "apc_mini"
# mode             = "note_offset"
# pages            = 2
# note_offset      = 64
# host_port_in     = "midi-pages-apc-out"
# host_port_out    = "midi-pages-apc-in"
# next_page_button     = { kind = "note", number = 98 }
# previous_page_button = { kind = "note", number = 99 }
