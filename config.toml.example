# midi-pages example configuration.
# Copy to config.toml and edit as needed. Run `midi-pages --list-ports` to see
# the exact port name strings reported by your OS.

[[device]]
name             = "Launchpad Mini MK3"
port_match       = "Launchpad Mini MK3"          # substring match against the OS port name
host_port_in     = "midi-pages-host-out"          # loopMIDI port: host writes here, we read
host_port_out    = "midi-pages-host-in"           # loopMIDI port: we write, host reads
driver           = "mini_mk3"                     # mini_mk3 | apc_mini
pages            = 4
note_offset      = 64
# Switch the device to programmer mode on startup so SysEx LED control works.
boot_sysex       = "F0 00 20 29 02 0D 0E 01 F7"
# Two physical buttons reserved for paging. Mini MK3 top-row arrows are CC 91/92.
page_up_button   = { kind = "cc", number = 91 }
page_down_button = { kind = "cc", number = 92 }
# Optional: physical buttons whose LEDs indicate the current page.
indicator_leds   = [
  { kind = "cc", number = 89 },
  { kind = "cc", number = 79 },
  { kind = "cc", number = 69 },
  { kind = "cc", number = 59 },
]

[[device]]
name             = "APC mini"
port_match       = "APC MINI"
host_port_in     = "midi-pages-apc-out"
host_port_out    = "midi-pages-apc-in"
driver           = "apc_mini"
pages            = 4
note_offset      = 64
page_up_button   = { kind = "note", number = 98 }
page_down_button = { kind = "note", number = 99 }
